<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

// 路径工具类
类 路径工具类 <公开>
{
    变量 静态目录 <公开 静态 类型 = 文本型>
    变量 会话目录 <公开 静态 类型 = 文本型>

    方法 初始化路径 <公开 静态>
    {
        静态目录 = 配置管理类.状态目录 + "/static"
        会话目录 = 配置管理类.会话目录
    }

    方法 获取安全路径 <公开 静态 类型 = 文本型>
    参数 基础路径 <类型 = 文本型>
    参数 请求路径 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        // 简单路径安全检查
        如果 (工具类.是否以文本开头 (请求路径, ".."))
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("非法路径"))
            返回 ("")
        }
        工具类.写空错误 (错误对象)
        返回 (基础路径 + "/" + 请求路径)
    }
}
