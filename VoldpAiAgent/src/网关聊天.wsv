// 网关聊天类 - 处理聊天请求
类 网关聊天类 <公开>
{
    方法 处理聊天请求 <公开 静态>
    参数 上下文 <类型 = Gin上下文>
    {
        // 从请求体获取参数
        变量 会话ID <类型 = 文本型>
        会话ID = 工具类.取请求体JSON值 (上下文, "session_id")
        变量 消息 <类型 = 文本型>
        消息 = 工具类.取请求体JSON值 (上下文, "message")
        变量 模型 <类型 = 文本型>
        模型 = 工具类.取请求体JSON值 (上下文, "model")
        变量 工作区 <类型 = 文本型>
        工作区 = 工具类.取请求体JSON值 (上下文, "workspace")

        // 验证参数
        如果 (会话ID == "")
        {
            上下文.写出JSON (400, Gin哈希表.创建Gin哈希表 ("error", "session_id is required"))
            返回
        }
        如果 (消息 == "")
        {
            上下文.写出JSON (400, Gin哈希表.创建Gin哈希表 ("error", "message is required"))
            返回
        }

        // 获取会话
        变量 错误 <类型 = 错误接口 值 = 空对象>
        变量 会话 <类型 = 会话模型>
        会话 = 会话操作类.获取会话 (数据库管理类.数据库, 会话ID, 错误.取地址 ())
        如果 (工具类.错误非空 (错误))
        {
            上下文.写出JSON (404, Gin哈希表.创建Gin哈希表 ("error", "Session not found"))
            返回
        }

        // 确定使用的模型
        如果 (模型 == "")
        {
            模型 = 会话.模型
        }
        如果 (模型 == "")
        {
            模型 = "gpt-3.5-turbo"
        }

        // 保存用户消息到数据库
        会话操作类.添加消息 (数据库管理类.数据库, 会话ID, "user", 消息, 错误.取地址 ())

        // 更新会话标题（如果是第一条消息且标题为默认值）
        如果 (会话.标题 == "新会话" 且 会话.手动标题 == 假)
        {
            变量 新标题 <类型 = 文本型>
            如果 (取文本长度 (消息) > 64)
            {
                新标题 = 取文本左边 (消息, 64)
            }
            否则
            {
                新标题 = 消息
            }
            变量 标题错误 <类型 = 错误接口 值 = 空对象>
            会话操作类.更新标题 (数据库管理类.数据库, 会话ID, 新标题, 标题错误.取地址 ())
            会话.标题 = 新标题
        }

        // 获取供应商配置
        变量 供应商列表 <类型 = "供应商模型 []" 值 = 空对象>
        数据库管理类.数据库.置Where条件 ("enabled = ?", 真).置Order条件 ("id ASC").查找 (Gorm.取地址 (供应商列表), "1=1")

        变量 API地址 <类型 = 文本型>
        变量 API密钥 <类型 = 文本型>
        变量 供应商标识 <类型 = 文本型>

        如果 (取数组成员数 (供应商列表) > 0)
        {
            // 使用第一个已启用的供应商
            变量 供应商 <类型 = 供应商模型>
            供应商 = 供应商列表 [0]
            // 从供应商配置中解析API地址和密钥
            API地址 = 网关聊天类.解析供应商配置 (供应商.配置, "base_url")
            API密钥 = 网关聊天类.解析供应商配置 (供应商.配置, "api_key")
            供应商标识 = 供应商.名称
        }

        // 创建流通道
        变量 流ID <类型 = 文本型>
        流ID = 聊天流管理类.创建流通道 (会话ID)

        // 启动AI聊天流（后台协程）
        聊天流管理类.启动AI聊天流 (流ID, 会话ID, 消息, 模型, API地址, API密钥)

        // 返回stream_id给前端
        变量 结果 <类型 = Gin哈希表>
        结果 = Gin哈希表.创建Gin哈希表 ("stream_id", 流ID).添加 ("session_id", 会话ID).添加 ("title", 会话.标题).添加 ("pending_started_at", 工具类.取当前时间戳 ()).添加 ("effective_model", 模型).添加 ("effective_model_provider", 供应商标识)
        上下文.写出JSON (200, 结果)
    }

    方法 解析供应商配置 <公开 静态 类型 = 文本型>
    参数 配置文本 <类型 = 文本型>
    参数 键名 <类型 = 文本型>
    {
        // 配置格式: "base_url=xxx|api_key=xxx" 或 JSON格式
        变量 结果 <类型 = 文本型>
        结果 = ""
        变量 搜索键 <类型 = 文本型>
        搜索键 = 键名 + "="
        变量 起始位置 <类型 = 整数>
        起始位置 = 寻找文本 (配置文本, 搜索键)
        如果 (起始位置 >= 0)
        {
            起始位置 = 起始位置 + 取文本长度 (搜索键)
            变量 结束位置 <类型 = 整数>
            结束位置 = 寻找文本 (配置文本, "|", 起始位置)
            如果 (结束位置 < 0)
            {
                结束位置 = 取文本长度 (配置文本)
            }
            结果 = 取文本中间 (配置文本, 起始位置, 结束位置 - 起始位置)
        }
        返回 (结果)
    }
}
