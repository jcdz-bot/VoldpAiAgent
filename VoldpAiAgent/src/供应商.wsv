<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 供应商操作类 <公开>
{
    方法 获取供应商列表 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 供应商列表 <类型 = "供应商模型 []">
    参数 错误对象 <类型 = 错误接口地址>
    {
        数据库.置Order条件 ("id ASC").查找 (Gorm.取地址 (供应商列表), "1=1")
        工具类.写空错误 (错误对象)
    }

    方法 获取供应商 <公开 静态 类型 = 供应商模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 供应商ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 供应商 <类型 = 供应商模型>
        数据库.取首记录 (供应商, "name = ?", 供应商ID)
        如果 (供应商.ID == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("供应商不存在"))
            返回 (供应商)
        }
        工具类.写空错误 (错误对象)
        返回 (供应商)
    }

    方法 创建供应商 <公开 静态 类型 = 供应商模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 名称 <类型 = 文本型>
    参数 类型值 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 供应商 <类型 = 供应商模型>
        供应商.名称 = 名称
        供应商.类型 = 类型值
        供应商.启用 = 真
        数据库.插入 (供应商)
        工具类.写空错误 (错误对象)
        返回 (供应商)
    }

    方法 更新供应商 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 供应商ID <类型 = 文本型>
    参数 名称 <类型 = 文本型>
    参数 类型值 <类型 = 文本型>
    参数 启用 <类型 = 逻辑型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 供应商 <类型 = 供应商模型>
        数据库.取首记录 (供应商, "name = ?", 供应商ID)
        如果 (供应商.ID == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("供应商不存在"))
            返回
        }
        供应商.名称 = 名称
        供应商.类型 = 类型值
        供应商.启用 = 启用
        数据库.保存 (到任意值 (供应商))
        工具类.写空错误 (错误对象)
    }

    方法 删除供应商 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 供应商ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 供应商 <类型 = 供应商模型>
        数据库.取首记录 (供应商, "name = ?", 供应商ID)
        如果 (供应商.ID == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("供应商不存在"))
            返回
        }
        数据库.删除 (到任意值 (供应商))
        工具类.写空错误 (错误对象)
    }

    方法 获取供应商配置 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 供应商列表 <类型 = "供应商模型 []">
    参数 错误对象 <类型 = 错误接口地址>
    {
        数据库.置Order条件 ("id ASC").查找 (Gorm.取地址 (供应商列表), "1=1")
        工具类.写空错误 (错误对象)
    }
}
