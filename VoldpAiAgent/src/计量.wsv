<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

// 计量类
类 计量类 <公开>
{
    变量 输入令牌 <公开 静态 类型 = 长整数>
    变量 输出令牌 <公开 静态 类型 = 长整数>
    变量 估算费用 <公开 静态 类型 = 小数>

    方法 记录使用量 <公开 静态>
    参数 会话ID <类型 = 文本型>
    参数 输入 <类型 = 长整数>
    参数 输出 <类型 = 长整数>
    参数 费用 <类型 = 小数>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库管理类.数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID != "")
        {
            会话.输入令牌数 = 会话.输入令牌数 + 输入
            会话.输出令牌数 = 会话.输出令牌数 + 输出
            会话.估算费用 = 会话.估算费用 + 费用
            数据库管理类.数据库.保存 (到任意值 (会话))
        }
        工具类.写空错误 (错误对象)
    }

    方法 获取使用量 <公开 静态 类型 = 文本型>
    参数 会话ID <类型 = 文本型>
    {
        变量 会话 <类型 = 会话模型>
        数据库管理类.数据库.取首记录 (会话, "session_id = ?", 会话ID)
        返回 ("输入: " + 到文本 (会话.输入令牌数) + " 输出: " + 到文本 (会话.输出令牌数))
    }
}
