<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

# 工作区操作类

类 工作区操作类 <公开>
{
    方法 获取工作区列表 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 工作区列表 <类型 = "工作区模型 []">
    参数 错误对象 <类型 = 错误接口地址>
    {
        数据库.置Order条件 ("id ASC").查找 (Gorm.取地址 (工作区列表), "1=1")
        工具类.写空错误 (错误对象)
    }

    方法 获取工作区 <公开 静态 类型 = 工作区模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 工作区ID <类型 = 整数>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 工作区 <类型 = 工作区模型>
        数据库.取首记录 (工作区, "id = ?", 工作区ID)
        如果 (工作区.ID == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("工作区不存在"))
            返回 (工作区)
        }
        工具类.写空错误 (错误对象)
        返回 (工作区)
    }

    方法 添加工作区 <公开 静态 类型 = 工作区模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 路径 <类型 = 文本型>
    参数 名称 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 工作区 <类型 = 工作区模型>
        工作区.路径 = 路径
        工作区.名称 = 名称
        工作区.最后使用时间 = 工具类.取当前时间戳 ()
        数据库.插入 (工作区)
        工具类.写空错误 (错误对象)
        返回 (工作区)
    }

    方法 删除工作区 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 工作区ID <类型 = 整数>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 工作区 <类型 = 工作区模型>
        数据库.取首记录 (工作区, "id = ?", 工作区ID)
        如果 (工作区.ID == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("工作区不存在"))
            返回
        }
        数据库.删除 (到任意值 (工作区))
        工具类.写空错误 (错误对象)
    }

    方法 更新最后使用时间 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 工作区ID <类型 = 整数>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 工作区 <类型 = 工作区模型>
        数据库.取首记录 (工作区, "id = ?", 工作区ID)
        如果 (工作区.ID != 0)
        {
            工作区.最后使用时间 = 工具类.取当前时间戳 ()
            数据库.保存 (到任意值 (工作区))
        }
        工具类.写空错误 (错误对象)
    }
}
