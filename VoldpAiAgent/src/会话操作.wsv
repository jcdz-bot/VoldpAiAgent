<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 会话操作类 <公开>
{
    方法 创建会话 <公开 静态 类型 = 会话模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 标题 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 新会话 <类型 = 会话模型>
        新会话.ID = 工具类.生成UUID ()
        新会话.标题 = 标题
        如果 (新会话.标题 == "")
        {
            新会话.标题 = "新会话"
        }
        新会话.创建时间 = 工具类.取当前时间戳 ()
        新会话.更新时间 = 工具类.取当前时间戳 ()
        新会话.固定 = 假
        新会话.归档 = 假
        新会话.供应商 = ""
        新会话.模型 = ""
        新会话.配置文件 = "default"
        新会话.工作区 = 配置管理类.默认工作区
        数据库.插入 (新会话)

        工具类.写空错误 (错误对象)
        返回 (新会话)
    }

    方法 获取会话 <公开 静态 类型 = 会话模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID == "")
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("会话不存在"))
            返回 (会话)
        }

        工具类.写空错误 (错误对象)
        返回 (会话)
    }

    方法 删除会话 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID == "")
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("会话不存在"))
            返回
        }

        // 删除关联消息
        变量 关联消息 <类型 = 消息模型>
        数据库.置Where条件 ("session_id = ?", 会话ID).删除 (到任意值 (关联消息))

        // 删除关联待办
        变量 关联待办 <类型 = 待办模型>
        数据库.置Where条件 ("session_id = ?", 会话ID).删除 (到任意值 (关联待办))

        // 删除会话本身
        数据库.删除 (到任意值 (会话))

        工具类.写空错误 (错误对象)
    }

    方法 获取会话列表 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话列表 <类型 = "会话模型 []">
    参数 错误对象 <类型 = 错误接口地址>
    {
        数据库.置Order条件 ("updated_at DESC").查找 (Gorm.取地址 (会话列表), "1=1")
        工具类.写空错误 (错误对象)
    }

    方法 更新标题 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 新标题 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID == "")
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("会话不存在"))
            返回
        }

        会话.标题 = 新标题
        会话.手动标题 = 真
        会话.LLM标题已生成 = 假
        会话.更新时间 = 工具类.取当前时间戳 ()
        数据库.保存 (到任意值 (会话))

        工具类.写空错误 (错误对象)
    }

    方法 切换固定 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID == "")
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("会话不存在"))
            返回
        }

        会话.固定 = 取反 (会话.固定)
        会话.更新时间 = 工具类.取当前时间戳 ()
        数据库.保存 (到任意值 (会话))

        工具类.写空错误 (错误对象)
    }

    方法 切换归档 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID == "")
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("会话不存在"))
            返回
        }

        会话.归档 = 取反 (会话.归档)
        会话.更新时间 = 工具类.取当前时间戳 ()
        数据库.保存 (到任意值 (会话))

        工具类.写空错误 (错误对象)
    }

    方法 获取消息列表 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 消息列表 <类型 = "消息模型 []">
    参数 错误对象 <类型 = 错误接口地址>
    {
        数据库.置Where条件 ("session_id = ?", 会话ID).置Order条件 ("timestamp ASC").查找 (Gorm.取地址 (消息列表), "1=1")
        工具类.写空错误 (错误对象)
    }

    方法 添加消息 <公开 静态 类型 = 消息模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 角色 <类型 = 文本型>
    参数 内容 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 消息 <类型 = 消息模型>
        消息.会话ID = 会话ID
        消息.角色 = 角色
        消息.内容 = 内容
        消息.时间戳 = 工具类.取当前毫秒时间戳 ()
        数据库.插入 (消息)

        // 更新会话的消息计数和更新时间
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID != "")
        {
            会话.消息数 = 会话.消息数 + 1
            会话.更新时间 = 工具类.取当前时间戳 ()
            会话.最后消息时间 = 工具类.取当前时间戳 ()
            数据库.保存 (到任意值 (会话))
        }

        工具类.写空错误 (错误对象)
        返回 (消息)
    }

    方法 重试最后消息 <公开 静态 类型 = 文本型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 消息列表 <类型 = "消息模型 []" 值 = 空对象>
        数据库.置Where条件 ("session_id = ?", 会话ID).置Order条件 ("timestamp ASC").查找 (Gorm.取地址 (消息列表), "1=1")

        变量 计数 <类型 = 整数>
        计数 = 取数组成员数 (消息列表)
        如果 (计数 == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("没有可重试的消息"))
            返回 ("")
        }

        // 从后往前找最后一条用户消息
        变量 最后用户索引 <类型 = 整数>
        最后用户索引 = -1
        变量 倒序索引 <类型 = 整数>
        循环 (0, 计数, 倒序索引, 1)
        {
            如果 (消息列表 [计数 - 1 - 倒序索引].角色 == "user")
            {
                最后用户索引 = 计数 - 1 - 倒序索引
                跳出循环
            }
        }

        如果 (最后用户索引 == -1)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("没有用户消息可重试"))
            返回 ("")
        }

        变量 用户消息文本 <类型 = 文本型>
        用户消息文本 = 消息列表 [最后用户索引].内容

        // 删除从最后用户消息开始的所有消息
        变量 删除计数 <类型 = 整数>
        删除计数 = 计数 - 最后用户索引
        变量 删序索引 <类型 = 整数>
        循环 (0, 删除计数, 删序索引, 1)
        {
            数据库.删除 (到任意值 (消息列表 [最后用户索引 + 删序索引]))
        }

        // 更新会话消息计数
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID != "")
        {
            会话.消息数 = 最后用户索引
            会话.更新时间 = 工具类.取当前时间戳 ()
            数据库.保存 (到任意值 (会话))
        }

        工具类.写空错误 (错误对象)
        返回 (用户消息文本)
    }

    方法 撤销最后消息 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 消息列表 <类型 = "消息模型 []" 值 = 空对象>
        数据库.置Where条件 ("session_id = ?", 会话ID).置Order条件 ("timestamp ASC").查找 (Gorm.取地址 (消息列表), "1=1")

        变量 计数 <类型 = 整数>
        计数 = 取数组成员数 (消息列表)
        如果 (计数 == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("没有可撤销的消息"))
            返回
        }

        // 从后往前找最后一条用户消息
        变量 最后用户索引 <类型 = 整数>
        最后用户索引 = -1
        变量 索引 <类型 = 整数>
        循环 (0, 计数, 索引, 1)
        {
            如果 (消息列表 [计数 - 1 - 索引].角色 == "user")
            {
                最后用户索引 = 计数 - 1 - 索引
                跳出循环
            }
        }

        如果 (最后用户索引 == -1)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("没有用户消息可撤销"))
            返回
        }

        // 删除从最后用户消息开始的所有消息
        变量 删除计数2 <类型 = 整数>
        删除计数2 = 计数 - 最后用户索引
        变量 删序索引2 <类型 = 整数>
        循环 (0, 删除计数2, 删序索引2, 1)
        {
            数据库.删除 (到任意值 (消息列表 [最后用户索引 + 删序索引2]))
        }

        // 更新会话消息计数
        变量 会话2 <类型 = 会话模型>
        数据库.取首记录 (会话2, "session_id = ?", 会话ID)
        如果 (会话2.ID != "")
        {
            会话2.消息数 = 最后用户索引
            会话2.更新时间 = 工具类.取当前时间戳 ()
            数据库.保存 (到任意值 (会话2))
        }

        工具类.写空错误 (错误对象)
    }

    方法 获取会话状态 <公开 静态 类型 = 文本型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID == "")
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("会话不存在"))
            返回 ("")
        }

        工具类.写空错误 (错误对象)
        返回 (会话.标题)
    }

    方法 更新供应商模型 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 供应商 <类型 = 文本型>
    参数 模型 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 会话 <类型 = 会话模型>
        数据库.取首记录 (会话, "session_id = ?", 会话ID)
        如果 (会话.ID == "")
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("会话不存在"))
            返回
        }

        会话.供应商 = 供应商
        会话.模型 = 模型
        会话.更新时间 = 工具类.取当前时间戳 ()
        数据库.保存 (到任意值 (会话))

        工具类.写空错误 (错误对象)
    }
}
