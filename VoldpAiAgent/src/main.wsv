<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序 <@服务器.导入 = "github.com/gin-gonic/gin" @服务器.导入 = "github.com/gin-contrib/cors" @服务器.导入 = "gorm.io/gorm"
        @服务器.导入 = "gorm.io/driver/sqlite" @服务器.导入 = "github.com/golang-jwt/jwt/v5" @服务器.导入 = "net/http" @服务器.导入 = "encoding/json"
        @服务器.导入 = "sync" @服务器.导入 = "path/filepath" @服务器.导入 = "regexp" @服务器.导入 = "crypto/rand" @服务器.导入 = "crypto/sha256"
        @服务器.导入 = "encoding/hex" @服务器.导入 = "fmt" @服务器.导入 = "os" @服务器.导入 = "strconv" @服务器.导入 = "io" @服务器.导入 = "bufio"
        @服务器.导入 = "strings" @服务器.导入 = "bytes" @服务器.导入 = "time" @服务器.导入 = "encoding/base64">

# 主启动类 - 程序入口

类 启动类 <公开 基础类 = 程序类 @服务器.附属文件 = "static > static">
{
    方法 启动方法 <公开 类型 = 整数>
    {
        换行输出 ("[webui] Hermes WebUI 火山语言版本启动中...")

        // 初始化配置
        配置管理类.初始化 ()

        // 初始化数据库
        数据库管理类.初始化数据库 ()

        // 启动HTTP服务器
        变量 服务器 <类型 = HTTP服务器类>
        变量 引擎 <参考 类型 = Gin引擎类>
        服务器.地址 = ":" + 到文本 (配置管理类.端口)
        引擎 = Gin引擎类.取默认引擎 ()

        // 注册CORS中间件
        注册CORS中间件 (引擎)

        // 注册认证中间件
        注册认证中间件 (引擎)

        // 先注册所有API路由(必须在静态文件之前)
        路由管理类.当前引擎 = 引擎
        路由管理类.数据库 = 数据库管理类.数据库
        路由管理类.注册所有路由 ()

        // 使用可执行文件目录动态定位静态文件(由@服务器.附属文件属性在编译时自动复制到输出目录)
        变量 项目目录 <类型 = 文本型>
        项目目录 = 取可执行文件目录 () + "/static"
        换行输出 ("[debug] static dir: " + 项目目录)

        // 临时调试路由: 检测目录是否存在
        引擎.注册GET2 ("/_debug/path")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 结果 <类型 = 文本型>
            结果 = "exeDir=" + 取可执行文件目录 () + " staticDir=" + 项目目录
            上下文.写出文本 (200, 结果)
        }

        注册静态文件服务 (引擎, 项目目录)

        服务器.置处理程序 (引擎.HTTP处理程序接口)
        换行输出 ("  Hermes WebUI listening on http://" + 配置管理类.主机 + ":" + 到文本 (配置管理类.端口))
        换行输出 ("  Then open:     http://localhost:" + 到文本 (配置管理类.端口))

        服务器.监听并服务 ()
        返回 (0)
    }

    # @ func Rg_QuKeZhixingWenJianMuLu() string {
    # @     exePath, err := os.Executable()
    # @     if err != nil { return "." }
    # @     return filepath.Dir(exePath)
    # @ }

    方法 取可执行文件目录 <公开 静态 类型 = 文本型 @嵌入式方法 = "" @禁止流程检查 = 真>
    {
        @ Rg_QuKeZhixingWenJianMuLu()
    }

