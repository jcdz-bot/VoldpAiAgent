<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

// 数据库管理类
类 数据库管理类 <公开>
{
    变量 数据库 <公开 静态 参考 类型 = Gorm数据库类>

    方法 初始化数据库 <公开 静态>
    {
        变量 数据库路径 <类型 = 文本型>
        数据库路径 = 配置管理类.状态目录 + "/hermes.db"

        变量 错误 <类型 = 错误接口 值 = 空对象>
        数据库 = Gorm数据库类.打开 (GormSQLite驱动程序类.打开 (数据库路径), 空对象, 错误.取地址 ())
        如果 (工具类.错误非空 (错误))
        {
            换行输出 ("打开数据库失败")
            返回
        }

        // 自动迁移所有表
        错误 = 数据库.自动迁移 (新建对象 (会话模型))
        错误 = 数据库.自动迁移 (新建对象 (消息模型))
        错误 = 数据库.自动迁移 (新建对象 (设置模型))
        错误 = 数据库.自动迁移 (新建对象 (供应商模型))
        错误 = 数据库.自动迁移 (新建对象 (工作区模型))
        错误 = 数据库.自动迁移 (新建对象 (配置文件模型))
        错误 = 数据库.自动迁移 (新建对象 (插件模型))
        错误 = 数据库.自动迁移 (新建对象 (待办模型))
        错误 = 数据库.自动迁移 (新建对象 (轮次日志模型))
        错误 = 数据库.自动迁移 (新建对象 (运行日志模型))
        错误 = 数据库.自动迁移 (新建对象 (技能使用模型))

        换行输出 ("[ok] 数据库初始化完成: " + 数据库路径)
    }
}

// 会话模型
类 会话模型 <公开 @输出名 = "Session">
{
    变量 ID <公开 类型 = 文本型 @服务器.标签 = "gorm:\"column:session_id;primarykey\" json:\"session_id\"" @输出名 = "SessionID">
    变量 标题 <公开 类型 = 文本型 @服务器.标签 = "json:\"title\"" @输出名 = "Title">
    变量 创建时间 <公开 类型 = 长整数 @服务器.标签 = "json:\"created_at\"" @输出名 = "CreatedAt">
    变量 更新时间 <公开 类型 = 长整数 @服务器.标签 = "json:\"updated_at\"" @输出名 = "UpdatedAt">
    变量 固定 <公开 类型 = 逻辑型 @服务器.标签 = "json:\"pinned\"" @输出名 = "Pinned">
    变量 归档 <公开 类型 = 逻辑型 @服务器.标签 = "json:\"archived\"" @输出名 = "Archived">
    变量 供应商 <公开 类型 = 文本型 @服务器.标签 = "json:\"provider\"" @输出名 = "Provider">
    变量 模型 <公开 类型 = 文本型 @服务器.标签 = "json:\"model\"" @输出名 = "Model">
    变量 配置文件 <公开 类型 = 文本型 @服务器.标签 = "json:\"profile\"" @输出名 = "Profile">
    变量 工作区 <公开 类型 = 文本型 @服务器.标签 = "json:\"workspace\"" @输出名 = "Workspace">
    变量 个性 <公开 类型 = 文本型 @服务器.标签 = "json:\"personality\"" @输出名 = "Personality">
    变量 输入令牌数 <公开 类型 = 长整数 @服务器.标签 = "json:\"input_tokens\"" @输出名 = "InputTokens">
    变量 输出令牌数 <公开 类型 = 长整数 @服务器.标签 = "json:\"output_tokens\"" @输出名 = "OutputTokens">
    变量 估算费用 <公开 类型 = 小数 @服务器.标签 = "json:\"estimated_cost\"" @输出名 = "EstimatedCost">
    变量 手动标题 <公开 类型 = 逻辑型 @服务器.标签 = "json:\"manual_title\"" @输出名 = "ManualTitle">
    变量 LLM标题已生成 <公开 类型 = 逻辑型 @服务器.标签 = "json:\"llm_title_generated\"" @输出名 = "LLMTitleGenerated">
    变量 消息数 <公开 类型 = 整数 @服务器.标签 = "json:\"message_count\"" @输出名 = "MessageCount">
    变量 最后消息时间 <公开 类型 = 长整数 @服务器.标签 = "json:\"last_message_at\"" @输出名 = "LastMessageAt">
    变量 父会话ID <公开 类型 = 文本型 @服务器.标签 = "json:\"parent_session_id\"" @输出名 = "ParentSessionID">
    变量 会话来源 <公开 类型 = 文本型 @服务器.标签 = "json:\"session_source\"" @输出名 = "SessionSource">
    变量 消息列表 <公开 类型 = "消息模型 []" @服务器.标签 = "gorm:\"-\" json:\"messages\"" @输出名 = "Messages">
    变量 最后用量 <公开 类型 = 文本型 @服务器.标签 = "gorm:\"-\" json:\"last_usage\"" @输出名 = "LastUsage">
    变量 模型供应商 <公开 类型 = 文本型 @服务器.标签 = "json:\"model_provider\"" @输出名 = "ModelProvider">
    变量 活跃流ID <公开 类型 = 文本型 @服务器.标签 = "gorm:\"-\" json:\"active_stream_id\"" @输出名 = "ActiveStreamID">
    变量 上下文长度 <公开 类型 = 长整数 @服务器.标签 = "gorm:\"-\" json:\"context_length\"" @输出名 = "ContextLength">
    变量 阈值令牌 <公开 类型 = 长整数 @服务器.标签 = "gorm:\"-\" json:\"threshold_tokens\"" @输出名 = "ThresholdTokens">
    变量 项目ID <公开 类型 = 文本型 @服务器.标签 = "json:\"project_id\"" @输出名 = "ProjectID">
    变量 缓存读取令牌 <公开 类型 = 长整数 @服务器.标签 = "json:\"cache_read_tokens\"" @输出名 = "CacheReadTokens">
    变量 缓存写入令牌 <公开 类型 = 长整数 @服务器.标签 = "json:\"cache_write_tokens\"" @输出名 = "CacheWriteTokens">
    变量 待处理用户消息 <公开 类型 = 文本型 @服务器.标签 = "json:\"pending_user_message\"" @输出名 = "PendingUserMessage">
    变量 待处理开始时间 <公开 类型 = 长整数 @服务器.标签 = "json:\"pending_started_at\"" @输出名 = "PendingStartedAt">
    变量 网关路由 <公开 类型 = 文本型 @服务器.标签 = "json:\"gateway_routing\"" @输出名 = "GatewayRouting">
    变量 工作树路径 <公开 类型 = 文本型 @服务器.标签 = "json:\"worktree_path\"" @输出名 = "WorktreePath">
    变量 工作树分支 <公开 类型 = 文本型 @服务器.标签 = "json:\"worktree_branch\"" @输出名 = "WorktreeBranch">
    变量 启用工具集 <公开 类型 = 文本型 @服务器.标签 = "json:\"enabled_toolsets\"" @输出名 = "EnabledToolsets">
    变量 只读 <公开 类型 = 逻辑型 @服务器.标签 = "json:\"read_only\"" @输出名 = "ReadOnly">
}

