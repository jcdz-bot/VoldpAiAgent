        引擎.注册GET2 ("/api/personalities")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("{\"personalities\":[],\"default\":\"\"}"))
        }

        引擎.注册POST2 ("/api/personality/set")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 工具类.取请求体JSON值 (上下文, "session_id")
            变量 名称 <类型 = 文本型>
            名称 = 工具类.取请求体JSON值 (上下文, "name")
            如果 (会话ID != "")
            {
                变量 错误 <类型 = 错误接口 值 = 空对象>
                变量 会话 <类型 = 会话模型>
                会话 = 会话操作类.获取会话 (路由管理类.数据库, 会话ID, 错误.取地址 ())
                如果 (会话.ID != "")
                {
                    会话.个性 = 名称
                    会话.更新时间 = 工具类.取当前时间戳 ()
                    路由管理类.数据库.保存 (到任意值 (会话))
                }
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("personality", 名称))
        }

        // ===== 推理模式 =====
        引擎.注册GET2 ("/api/reasoning")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 推理设置 <类型 = 设置模型>
            路由管理类.数据库.取首记录 (推理设置, "key = ?", "reasoning_display")
            变量 显示 <类型 = 文本型>
            显示 = 推理设置.值
            如果 (显示 == "")
            {
                显示 = "collapsed"
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("display", 显示).添加 ("effort", "medium").添加 ("available", 真))
        }

        引擎.注册POST2 ("/api/reasoning")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 显示 <类型 = 文本型>
            显示 = 工具类.取请求体JSON值 (上下文, "display")
            变量 努力 <类型 = 文本型>
            努力 = 工具类.取请求体JSON值 (上下文, "effort")
            如果 (显示 != "")
            {
                工具类.保存设置 ("reasoning_display", 显示)
            }
            如果 (努力 != "")
            {
                工具类.保存设置 ("reasoning_effort", 努力)
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        // ===== 更新检查 =====
        引擎.注册POST2 ("/api/updates/check")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("updates_available", 假).添加 ("current_version", "1.0.0").添加 ("latest_version", "1.0.0"))
        }

        引擎.注册POST2 ("/api/updates/summary")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        引擎.注册POST2 ("/api/updates/apply")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("message", "Updates not available in standalone mode"))
        }

        引擎.注册POST2 ("/api/updates/force")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("message", "Updates not available in standalone mode"))
        }

        // ===== 网关状态 =====
        引擎.注册GET2 ("/api/gateway/status")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 供应商列表 <类型 = "供应商模型 []" 值 = 空对象>
            路由管理类.数据库.置Where条件 ("enabled = ? AND has_key = ?", 真, 真).查找 (Gorm.取地址 (供应商列表), "1=1")
            变量 已连接 <类型 = 逻辑型>
            已连接 = 取数组成员数 (供应商列表) > 0
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("connected", 已连接).添加 ("mode", "standalone").添加 ("agent_running", 假))
        }

        // ===== 技能 =====
        引擎.注册GET2 ("/api/skills")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("{\"skills\":[],\"categories\":[],\"count\":0,\"success\":true}"))
        }

        // ===== 日志 =====
        引擎.注册GET2 ("/api/logs")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("{\"logs\":[],\"files\":[]}"))
        }

        // ===== 会话导入 =====
        引擎.注册POST2 ("/api/session/import")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("message", "Import not available in standalone mode"))
        }

        // ===== 会话分支 =====
        引擎.注册POST2 ("/api/session/branch")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 工具类.取请求体JSON值 (上下文, "session_id")
            变量 消息索引 <类型 = 文本型>
            消息索引 = 工具类.取请求体JSON值 (上下文, "message_index")
            如果 (会话ID == "")
            {
                上下文.写出JSON (400, Gin哈希表.创建Gin哈希表 ("error", "session_id is required"))
                返回
            }
            变量 错误 <类型 = 错误接口 值 = 空对象>
            变量 原会话 <类型 = 会话模型>
            原会话 = 会话操作类.获取会话 (路由管理类.数据库, 会话ID, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (404, Gin哈希表.创建Gin哈希表 ("error", "会话不存在"))
                返回
            }
            // 创建分支会话
            变量 分支会话 <类型 = 会话模型>
            分支会话 = 会话操作类.创建会话 (路由管理类.数据库, 原会话.标题 + " (分支)", 错误.取地址 ())
            分支会话.父会话ID = 会话ID
            分支会话.会话来源 = "fork"
            分支会话.供应商 = 原会话.供应商
            分支会话.模型 = 原会话.模型
            分支会话.工作区 = 原会话.工作区
            路由管理类.数据库.保存 (到任意值 (分支会话))
            上下文.写出JSON (200, 到任意值 (分支会话))
        }

        // ===== 审批/澄清 =====
        引擎.注册GET2 ("/api/approval/pending")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("{\"pending\":null}"))
        }

        引擎.注册POST2 ("/api/session/draft")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        引擎.注册GET2 ("/api/clarify/pending")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("{\"pending\":null}"))
        }

        引擎.注册POST2 ("/api/clarify/respond")

        // ===== 后台任务 =====
        引擎.注册GET2 ("/api/background/status")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("running", 假))
        }

        引擎.注册POST2 ("/api/background")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("message", "Background tasks not available in standalone mode"))
        }

        引擎.注册POST2 ("/api/btw")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("message", "BTW not available in standalone mode"))
        }

        引擎.注册POST2 ("/api/goal")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        // ===== 提示词 =====
        引擎.注册GET2 ("/api/prompts")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("{\"prompts\":[]}"))
        }

        // ===== 关机 =====
        引擎.注册POST2 ("/api/shutdown")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
            // 在独立模式下不实际关机
        }

        // ===== 默认模型 =====
        引擎.注册POST2 ("/api/default-model")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 模型 <类型 = 文本型>
            模型 = 工具类.取请求体JSON值 (上下文, "model")
            变量 供应商 <类型 = 文本型>
            供应商 = 工具类.取请求体JSON值 (上下文, "provider")
            如果 (模型 != "")
            {
                工具类.保存设置 ("default_model", 模型)
            }
            如果 (供应商 != "")
            {
                工具类.保存设置 ("default_model_provider", 供应商)
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        // ===== 会话事件SSE =====
        引擎.注册GET2 ("/api/sessions/events")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            流式传输类.开始SSE (上下文)
            流式传输类.发送SSE事件 (上下文, "connected", "{\"type\":\"sessions_events\"}")
        }

        // ===== 网关流SSE =====
        引擎.注册GET2 ("/api/sessions/gateway/stream")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            流式传输类.开始SSE (上下文)
            流式传输类.发送SSE事件 (上下文, "connected", "{\"type\":\"gateway_stream\"}")
        }

        // ===== 工作区操作 =====
        引擎.注册POST2 ("/api/workspaces/add")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 路径 <类型 = 文本型>
            路径 = 工具类.取请求体JSON值 (上下文, "path")
            变量 名称 <类型 = 文本型>
            名称 = 工具类.取请求体JSON值 (上下文, "name")
            如果 (路径 == "")
            {
                上下文.写出JSON (400, Gin哈希表.创建Gin哈希表 ("error", "path is required"))
                返回
            }
            如果 (名称 == "")
            {
                名称 = 工具类.取路径最后部分 (路径)
            }
            变量 新工作区 <类型 = 工作区模型>
            新工作区.路径 = 路径
            新工作区.名称 = 名称
            新工作区.最后使用时间 = 工具类.取当前时间戳 ()
            路由管理类.数据库.插入 (新工作区)
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        引擎.注册POST2 ("/api/workspaces/remove")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 路径 <类型 = 文本型>
            路径 = 工具类.取请求体JSON值 (上下文, "path")
            变量 工作区 <类型 = 工作区模型>
            路由管理类.数据库.取首记录 (工作区, "path = ?", 路径)
            如果 (工作区.ID != 0)
            {
                路由管理类.数据库.删除 (到任意值 (工作区))
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        // ===== 会话清理 =====
        引擎.注册POST2 ("/api/sessions/cleanup")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("deleted", 0))
        }

        // ===== 会话搜索 =====
        引擎.注册GET2 ("/api/sessions/search")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 查询 <类型 = 文本型>
            查询 = 上下文.取查询 ("q", "")
            变量 会话列表 <类型 = "会话模型 []" 值 = 空对象>
            如果 (查询 != "")
            {
                路由管理类.数据库.置Where条件 ("title LIKE ?", "%" + 查询 + "%").置Order条件 ("updated_at DESC").查找 (Gorm.取地址 (会话列表), "1=1")
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("sessions", 到任意值 (会话列表)))
        }

        // ===== 会话用量 =====
        引擎.注册GET2 ("/api/session/usage")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取查询 ("session_id", "")
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("input_tokens", 0).添加 ("output_tokens", 0).添加 ("estimated_cost", 0))
        }

        // ===== 会话状态 =====
        引擎.注册GET2 ("/api/session/status")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取查询 ("session_id", "")
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("status", "idle").添加 ("has_active_stream", 假))
        }

        // ===== 插件 =====
        引擎.注册GET2 ("/api/plugins")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 插件列表 <类型 = "插件模型 []" 值 = 空对象>
            路由管理类.数据库.置Order条件 ("id ASC").查找 (Gorm.取地址 (插件列表), "1=1")
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("plugins", 到任意值 (插件列表)))
        }

        // ===== 仪表板 =====
        引擎.注册GET2 ("/api/dashboard/status")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("status", "ok").添加 ("uptime", 0))
        }

        换行输出 ("[ok] 所有路由注册完成")
    }
}
