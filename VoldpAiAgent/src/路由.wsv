<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 路由管理类 <公开>
{
    变量 当前引擎 <公开 静态 参考 类型 = Gin引擎类>
    变量 数据库 <公开 静态 参考 类型 = Gorm数据库类>

    方法 注册所有路由 <公开 静态>
    {
        变量 引擎 <参考 类型 = Gin引擎类>
        引擎 = 路由管理类.当前引擎

        引擎.注册POST2 ("/api/auth/login")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()

            变量 密码 <类型 = 文本型>
            密码 = 工具类.取请求体JSON值 (上下文, "password")

            // 从设置表读取密码哈希
            变量 密码设置 <类型 = 设置模型>
            路由管理类.数据库.取首记录 (密码设置, "key = ?", "password_hash")

            如果 (密码设置.值 == "")
            {
                上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("error", "未设置密码"))
                返回
            }

            如果 (认证工具类.哈希密码 (密码) != 密码设置.值)
            {
                上下文.写出JSON (401, Gin哈希表.创建Gin哈希表 ("error", "密码错误"))
                返回
            }

            变量 错误 <类型 = 错误接口 值 = 空对象>
            变量 令牌 <类型 = 文本型>
            令牌 = 认证工具类.生成JWT (密码设置.值, "admin", 配置管理类.会话TTL, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (500, Gin哈希表.创建Gin哈希表 ("error", "令牌生成失败"))
                返回
            }

            // 设置hermes_session cookie
            工具类.设置认证Cookie (上下文, 令牌, 配置管理类.会话TTL)
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("token", 令牌))
        }

        引擎.注册GET2 ("/api/auth/status")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()

            // 从设置表读取密码哈希
            变量 密码设置 <类型 = 设置模型>
            路由管理类.数据库.取首记录 (密码设置, "key = ?", "password_hash")

            变量 认证已启用 <类型 = 逻辑型>
            认证已启用 = 密码设置.值 != ""

            变量 结果 <类型 = Gin哈希表>
            结果 = Gin哈希表.创建Gin哈希表 ("auth_enabled", 认证已启用).添加 ("password_auth_enabled", 认证已启用).添加 ("passkeys_enabled", 假).添加 ("passkeys_count", 0).添加 ("passkey_feature_flag", 假)

            如果 (认证已启用 == 假)
            {
                结果.添加 ("authenticated", 真)
                上下文.写出JSON (200, 结果)
                返回
            }

            变量 令牌 <类型 = 文本型>
            令牌 = 工具类.取认证令牌 (上下文)
            如果 (令牌 == "")
            {
                结果.添加 ("authenticated", 假)
                上下文.写出JSON (200, 结果)
                返回
            }

            变量 验证错误 <类型 = 错误接口 值 = 空对象>
            变量 用户ID <类型 = 文本型>
            用户ID = 认证工具类.验证JWT (密码设置.值, 令牌, 验证错误.取地址 ())
            如果 (工具类.错误非空 (验证错误))
            {
                结果.添加 ("authenticated", 假)
                上下文.写出JSON (200, 结果)
                返回
            }
            结果.添加 ("authenticated", 真)
            上下文.写出JSON (200, 结果)
        }

        引擎.注册POST2 ("/api/auth/logout")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            工具类.清除认证Cookie (上下文)
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        引擎.注册GET2 ("/api/sessions")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话列表 <类型 = "会话模型 []" 值 = 空对象>
            路由管理类.数据库.置Order条件 ("updated_at DESC").查找 (Gorm.取地址 (会话列表), "1=1")
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("sessions", 到任意值 (会话列表)))
        }

        引擎.注册POST2 ("/api/sessions")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 错误 <类型 = 错误接口 值 = 空对象>
            变量 会话 <类型 = 会话模型>
            会话 = 会话操作类.创建会话 (路由管理类.数据库, "", 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (500, Gin哈希表.创建Gin哈希表 ("error", "创建会话失败"))
                返回
            }
            上下文.写出JSON (200, 到任意值 (会话))
        }

        引擎.注册GET2 ("/api/sessions/:session_id")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取URL参数 ("session_id")
            变量 错误 <类型 = 错误接口 值 = 空对象>
            变量 会话 <类型 = 会话模型>
            会话 = 会话操作类.获取会话 (路由管理类.数据库, 会话ID, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (404, Gin哈希表.创建Gin哈希表 ("error", "会话不存在"))
                返回
            }
            上下文.写出JSON (200, 到任意值 (会话))
        }

        引擎.注册POST2 ("/api/sessions/:session_id/pin")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取URL参数 ("session_id")
            变量 错误 <类型 = 错误接口 值 = 空对象>
            会话操作类.切换固定 (路由管理类.数据库, 会话ID, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (500, Gin哈希表.创建Gin哈希表 ("error", "切换固定失败"))
                返回
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("message", "固定状态已切换"))
        }

        引擎.注册POST2 ("/api/sessions/:session_id/archive")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取URL参数 ("session_id")
            变量 错误 <类型 = 错误接口 值 = 空对象>
            会话操作类.切换归档 (路由管理类.数据库, 会话ID, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (500, Gin哈希表.创建Gin哈希表 ("error", "切换归档失败"))
                返回
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("message", "归档状态已切换"))
        }

        引擎.注册GET2 ("/api/sessions/:session_id/messages")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取URL参数 ("session_id")
            变量 消息列表 <类型 = "消息模型 []" 值 = 空对象>
            路由管理类.数据库.置Where条件 ("session_id = ?", 会话ID).置Order条件 ("timestamp ASC").查找 (Gorm.取地址 (消息列表), "1=1")
            如果 (取数组成员数 (消息列表) == 0)
            {
                上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("[]"))
            }
            否则
            {
                上下文.写出JSON (200, 到任意值 (消息列表))
            }
        }

        引擎.注册POST2 ("/api/sessions/:session_id/messages")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取URL参数 ("session_id")
            变量 内容 <类型 = 文本型>
            内容 = 工具类.取请求体JSON值 (上下文, "content")
            变量 错误 <类型 = 错误接口 值 = 空对象>
            变量 消息 <类型 = 消息模型>
            消息 = 会话操作类.添加消息 (路由管理类.数据库, 会话ID, "user", 内容, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (500, Gin哈希表.创建Gin哈希表 ("error", "发送消息失败"))
                返回
            }
            上下文.写出JSON (200, 到任意值 (消息))
        }

        引擎.注册POST2 ("/api/sessions/:session_id/retry")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取URL参数 ("session_id")
            变量 错误 <类型 = 错误接口 值 = 空对象>
            变量 用户消息 <类型 = 文本型>
            用户消息 = 会话操作类.重试最后消息 (路由管理类.数据库, 会话ID, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (400, Gin哈希表.创建Gin哈希表 ("error", "重试消息失败"))
                返回
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("user_message", 用户消息))
        }

        引擎.注册POST2 ("/api/sessions/:session_id/undo")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 会话ID <类型 = 文本型>
            会话ID = 上下文.取URL参数 ("session_id")
            变量 错误 <类型 = 错误接口 值 = 空对象>
            会话操作类.撤销最后消息 (路由管理类.数据库, 会话ID, 错误.取地址 ())
            如果 (工具类.错误非空 (错误))
            {
                上下文.写出JSON (400, Gin哈希表.创建Gin哈希表 ("error", "撤销消息失败"))
                返回
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("message", "消息已撤销"))
        }

        引擎.注册GET2 ("/api/settings")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            // 读取所有设置键值对,合并为扁平JSON
            变量 设置列表 <类型 = "设置模型 []" 值 = 空对象>
            路由管理类.数据库.查找 (Gorm.取地址 (设置列表), "1=1")
            // 构建结果哈希表
            变量 结果2 <类型 = Gin哈希表>
            结果2 = Gin哈希表.创建Gin哈希表 ("default_workspace", 配置管理类.默认工作区)
            // 遍历设置列表,将键值对添加到结果
            变量 认证已启用 <类型 = 逻辑型>
            认证已启用 = 假
            计次循环 (取数组成员数 (设置列表))
            {
                如果 (设置列表 [取循环索引 ()].键 == "password_hash")
                {
                    认证已启用 = 设置列表 [取循环索引 ()].值 != ""
                }
                否则
                {
                    结果2.添加 (设置列表 [取循环索引 ()].键, 设置列表 [取循环索引 ()].值)
                }
            }
            结果2.添加 ("auth_enabled", 认证已启用)
            结果2.添加 ("password_auth_enabled", 认证已启用)
            结果2.添加 ("send_key", "enter")
            结果2.添加 ("show_token_usage", 假)
            结果2.添加 ("show_thinking", 真)
            结果2.添加 ("theme", "dark")
            结果2.添加 ("skin", "default")
            结果2.添加 ("default_model_provider", "")
            结果2.添加 ("default_model", "")
            上下文.写出JSON (200, 结果2)
        }

        引擎.注册POST2 ("/api/settings")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()

            // 处理密码设置(特殊字段)
            变量 密码 <类型 = 文本型>
            密码 = 工具类.取请求体JSON值 (上下文, "password")
            如果 (密码 != "")
            {
                工具类.保存设置 ("password_hash", 认证工具类.哈希密码 (密码))
            }

            // 处理认证禁用
            变量 认证启用 <类型 = 文本型>
            认证启用 = 工具类.取请求体JSON值 (上下文, "auth_enabled")
            如果 (认证启用 == "false")
            {
                工具类.保存设置 ("password_hash", "")
            }

            // 处理默认工作区
            变量 工作区 <类型 = 文本型>
            工作区 = 工具类.取请求体JSON值 (上下文, "default_workspace")
            如果 (工作区 != "")
            {
                工具类.保存设置 ("default_workspace", 工作区)
            }

            // 处理其他通用设置字段
            变量 主题 <类型 = 文本型>
            主题 = 工具类.取请求体JSON值 (上下文, "theme")
            如果 (主题 != "")
            {
                工具类.保存设置 ("theme", 主题)
            }

            变量 皮肤 <类型 = 文本型>
            皮肤 = 工具类.取请求体JSON值 (上下文, "skin")
            如果 (皮肤 != "")
            {
                工具类.保存设置 ("skin", 皮肤)
            }

            变量 默认供应商 <类型 = 文本型>
            默认供应商 = 工具类.取请求体JSON值 (上下文, "default_model_provider")
            如果 (默认供应商 != "")
            {
                工具类.保存设置 ("default_model_provider", 默认供应商)
            }

            变量 默认模型 <类型 = 文本型>
            默认模型 = 工具类.取请求体JSON值 (上下文, "default_model")
            如果 (默认模型 != "")
            {
                工具类.保存设置 ("default_model", 默认模型)
            }

            变量 发送键 <类型 = 文本型>
            发送键 = 工具类.取请求体JSON值 (上下文, "send_key")
            如果 (发送键 != "")
            {
                工具类.保存设置 ("send_key", 发送键)
            }

            变量 显示思考 <类型 = 文本型>
            显示思考 = 工具类.取请求体JSON值 (上下文, "show_thinking")
            如果 (显示思考 != "")
            {
                工具类.保存设置 ("show_thinking", 显示思考)
            }

            变量 显示令牌用量 <类型 = 文本型>
            显示令牌用量 = 工具类.取请求体JSON值 (上下文, "show_token_usage")
            如果 (显示令牌用量 != "")
            {
                工具类.保存设置 ("show_token_usage", 显示令牌用量)
            }

            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真))
        }

        引擎.注册GET2 ("/api/workspaces")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 工作区列表 <类型 = "工作区模型 []" 值 = 空对象>
            路由管理类.数据库.置Order条件 ("id ASC").查找 (Gorm.取地址 (工作区列表), "1=1")
            如果 (取数组成员数 (工作区列表) == 0)
            {
                上下文.写出数据 (200, "application/json; charset=utf-8", 文本到字节数组 ("{\"workspaces\":[]}"))
            }
            否则
            {
                上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("workspaces", 到任意值 (工作区列表)))
            }
        }

        引擎.注册GET2 ("/api/providers")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            // 使用嵌入式Go代码过滤敏感信息
            工具类.取供应商列表 (上下文)
        }

        引擎.注册POST2 ("/api/providers")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            // 兼容前端格式: {provider: "openai", api_key: "sk-xxx", base_url: "https://..."}
            变量 供应商标识 <类型 = 文本型>
            供应商标识 = 工具类.取请求体JSON值 (上下文, "provider")
            变量 API密钥 <类型 = 文本型>
            API密钥 = 工具类.取请求体JSON值 (上下文, "api_key")
            变量 基础URL <类型 = 文本型>
            基础URL = 工具类.取请求体JSON值 (上下文, "base_url")
            如果 (供应商标识 == "")
            {
                上下文.写出JSON (400, Gin哈希表.创建Gin哈希表 ("error", "provider is required"))
                返回
            }
            // 查找是否已存在
            变量 供应商 <类型 = 供应商模型>
            路由管理类.数据库.取首记录 (供应商, "name = ?", 供应商标识)
            // 构建配置字符串
            变量 配置 <类型 = 文本型>
            配置 = "base_url=" + 基础URL + "|api_key=" + API密钥
            如果 (供应商.ID == 0)
            {
                // 新建
                供应商.名称 = 供应商标识
                供应商.类型 = 供应商标识
                供应商.配置 = 配置
                供应商.启用 = 真
                供应商.可配置 = 真
                供应商.有密钥 = API密钥 != ""
                供应商.密钥来源 = "config_yaml"
                供应商.模型总数 = 0
                路由管理类.数据库.插入 (供应商)
            }
            否则
            {
                // 更新
                供应商.配置 = 配置
                供应商.启用 = 真
                供应商.有密钥 = API密钥 != ""
                供应商.密钥来源 = "config_yaml"
                路由管理类.数据库.保存 (到任意值 (供应商))
            }
            上下文.写出JSON (200, Gin哈希表.创建Gin哈希表 ("ok", 真).添加 ("provider", 供应商标识).添加 ("action", "saved"))
        }

        引擎.注册POST2 ("/api/providers/add")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            变量 名称 <类型 = 文本型>
            名称 = 工具类.取请求体JSON值 (上下文, "name")
            变量 类型 <类型 = 文本型>
            类型 = 工具类.取请求体JSON值 (上下文, "type")
            变量 配置 <类型 = 文本型>
            配置 = 工具类.取请求体JSON值 (上下文, "config")
            变量 供应商 <类型 = 供应商模型>
            供应商.名称 = 名称
            供应商.类型 = 类型
            供应商.配置 = 配置
            供应商.启用 = 真
            供应商.可配置 = 真
            供应商.有密钥 = 配置 != ""
            供应商.密钥来源 = "config_yaml"
            供应商.模型总数 = 0
            路由管理类.数据库.插入 (供应商)
            上下文.写出JSON (200, 到任意值 (供应商))
        }

        引擎.注册POST2 ("/api/providers/delete")
        {
            变量 上下文 <参考 类型 = Gin上下文>
            上下文 = Gin路由处理程序接口.取上下文 ()
            // 兼容前端格式: {provider: "openai"}
            变量 供应商标识 <类型 = 文本型>
            供应商标识 = 工具类.取请求体JSON值 (上下文, "provider")
            变量 名称 <类型 = 文本型>
            名称 = 工具类.取请求体JSON值 (上下文, "name")
