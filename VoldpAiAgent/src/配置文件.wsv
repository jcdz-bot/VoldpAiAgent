<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

# 配置文件操作类

类 配置文件操作类 <公开>
{
    方法 获取配置文件列表 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 配置文件列表 <类型 = "配置文件模型 []">
    参数 错误对象 <类型 = 错误接口地址>
    {
        数据库.置Order条件 ("id ASC").查找 (Gorm.取地址 (配置文件列表), "1=1")
        工具类.写空错误 (错误对象)
    }

    方法 获取配置文件 <公开 静态 类型 = 配置文件模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 名称 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 配置文件 <类型 = 配置文件模型>
        数据库.取首记录 (配置文件, "name = ?", 名称)
        如果 (配置文件.ID == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("配置文件不存在"))
            返回 (配置文件)
        }
        工具类.写空错误 (错误对象)
        返回 (配置文件)
    }

    方法 创建配置文件 <公开 静态 类型 = 配置文件模型>
    参数 数据库 <类型 = Gorm数据库类>
    参数 名称 <类型 = 文本型>
    参数 显示名称 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 配置文件 <类型 = 配置文件模型>
        配置文件.名称 = 名称
        配置文件.显示名称 = 显示名称
        配置文件.Hermes主目录 = 配置管理类.Hermes主目录
        数据库.插入 (配置文件)
        工具类.写空错误 (错误对象)
        返回 (配置文件)
    }

    方法 删除配置文件 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 名称 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 配置文件 <类型 = 配置文件模型>
        数据库.取首记录 (配置文件, "name = ?", 名称)
        如果 (配置文件.ID == 0)
        {
            工具类.写错误 (错误对象, 工具类.创建错误 ("配置文件不存在"))
            返回
        }
        数据库.删除 (到任意值 (配置文件))
        工具类.写空错误 (错误对象)
    }
}
