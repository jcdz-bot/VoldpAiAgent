<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

# 轮次日志类

类 轮次日志类 <公开>
{
    方法 写入轮次日志 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 轮次索引 <类型 = 整数>
    参数 角色 <类型 = 文本型>
    参数 摘要 <类型 = 文本型>
    参数 错误对象 <类型 = 错误接口地址>
    {
        变量 日志 <类型 = 轮次日志模型>
        日志.会话ID = 会话ID
        日志.轮次索引 = 轮次索引
        日志.角色 = 角色
        日志.摘要 = 摘要
        日志.时间戳 = 工具类.取当前时间戳 ()
        数据库.插入 (日志)
        工具类.写空错误 (错误对象)
    }

    方法 获取轮次日志 <公开 静态>
    参数 数据库 <类型 = Gorm数据库类>
    参数 会话ID <类型 = 文本型>
    参数 日志列表 <类型 = "轮次日志模型 []">
    参数 错误对象 <类型 = 错误接口地址>
    {
        数据库.置Where条件 ("session_id = ?", 会话ID).置Order条件 ("turn_index ASC").查找 (Gorm.取地址 (日志列表), "1=1")
        工具类.写空错误 (错误对象)
    }
}
